# Which PostHog region to provision against. Defaults to US.
POSTHOG_PROVISIONING_HOST=https://us.posthog.com

# Optional. A verification token minted in your PostHog org settings links this
# CIMD client to your org and raises the rate limit from 10/hr to 100/hr.
# Leave unset to run unverified.
POSTHOG_VERIFICATION_TOKEN=

# Required to run the provisioning flow. Neon serverless Postgres connection
# string — each provisioned farm (team id, phc_ key, encrypted tokens) is
# persisted here. Provisioning throws without it.
DATABASE_URL=

# Required to run the provisioning flow. Hex key for AES-256-GCM encryption of
# stored OAuth tokens, and for signing per-farm dashboard capability links.
# Generate with: openssl rand -hex 32
HOGFARM_ENC_KEY=
